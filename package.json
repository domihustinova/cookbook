{
  "name": "cookbook",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "biome": "biome check .",
    "biome:fix": "biome check --write .",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "pw": "playwright test",
    "pw:report": "playwright show-report",
    "pw:a11y": "playwright test --project=a11y-*",
    "reducer": "tsx tests/accessibility/support/scripts/reducer.ts",
    "htmlIndex": "tsx tests/accessibility/support/scripts/htmlIndex.ts",
    "pw:a11y:cleanup": "rm -rf public/data/ public/reports/ public/index.html",
    "pw:a11y:local": "tsx tests/accessibility/support/scripts/localRun.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.0.15",
    "@vercel/speed-insights": "^2.0.0",
    "next": "^16.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^2.4.8",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "axe-html-reporter": "^2.2.11",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-extended": "^7.0.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": "biome check"
  },
  "overrides": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
